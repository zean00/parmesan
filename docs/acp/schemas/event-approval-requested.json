{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [{ "$ref": "./event-base.json" }],
  "properties": {
    "kind": { "const": "approval.requested" },
    "data": {
      "type": "object",
      "required": ["approval_id", "tool_id", "message", "expires_at"],
      "properties": {
        "approval_id": { "type": "string" },
        "tool_id": { "type": "string" },
        "message": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "required": ["data"]
}
