{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [{ "$ref": "./event-base.json" }],
  "properties": {
    "kind": { "const": "tool.blocked" },
    "data": {
      "type": "object",
      "required": ["tool_id", "reason"],
      "properties": {
        "tool_id": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  },
  "required": ["data"]
}
