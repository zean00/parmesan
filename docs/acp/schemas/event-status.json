{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [{ "$ref": "./event-base.json" }],
  "properties": {
    "kind": { "const": "status" },
    "data": {
      "type": "object",
      "required": ["code", "state"],
      "properties": {
        "code": { "type": "string" },
        "state": { "type": "string" }
      }
    }
  },
  "required": ["data"]
}
